{
  "name": "financial-tracker-root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c green,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { . .\\\\venv\\\\Scripts\\\\Activate.ps1; uvicorn backend.main:app --host 127.0.0.1 --port 8000 }\"",
    "dev:backend:reload": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { . .\\\\venv\\\\Scripts\\\\Activate.ps1; uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000 }\"",
    "dev:frontend": "npm run dev --prefix frontendwebapp",
    "desktop-dev": "cross-env ELECTRON_DEV=1 npm start --prefix desktop",
    "desktop-build": "npm run build --prefix frontendwebapp && npm run build --prefix desktop"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3"
  }
}
