{
  "name": "finledge-desktop",
  "private": true,
  "version": "1.0.0",
  "author": "Sachin Adhikari",
  "description": "Finledge - Financial Tracker desktop application",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/sachinadk2011/FinLedge-App.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.finledge.tracker",
    "productName": "Finledge",
    "compression": "maximum",
    "copyright": "Copyright © 2026 Sachin Adhikari",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "sachinadk2011",
        "repo": "FinLedge-App",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "finledge_icon.ico",
      "finledge_icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/sidecar/finledge-engine.exe",
        "to": "engine/finledge-engine.exe"
      },
      {
        "from": "../frontendwebapp/dist",
        "to": "frontendwebapp/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "finledge_icon.ico",
      "publisherName": "Sachin Adhikari",
      "requestedExecutionLevel": "asInvoker",
      "legalTrademarks": "Sachin Adhikari",
      "artifactName": "Finledge-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerHeaderIcon": "finledge_icon.ico"
    }
  }
}
